# ─────────────────────────────────────────────────────────────────────────────
# NSE Stock Dashboard — Backend environment TEMPLATE
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=MyApp
APP_ENV=development          # development | production
DEBUG=true

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong key:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── PostgreSQL Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ERP
DB_USER=postgres
DB_PASSWORD=your-postgres-password

# ── Optional: Gmail integration ───────────────────────────────────────────────
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Optional: Ollama (local LLM) ──────────────────────────────────────────────
# Install Ollama: https://ollama.ai  then run: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
